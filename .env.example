# OpenAI summarization settings.
# Set OPENAI_API_KEY in GitHub Actions secrets or your local shell to enable real AI summaries.
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_SUMMARY_LIMIT=20
OPENAI_API_KEY=

# RSS fetch settings.
RSS_FETCH_LIMIT_PER_SOURCE=8
RSS_FETCH_RETRIES=2
RSS_FETCH_TIMEOUT_MS=12000

# Orchestration OS — claude-code runtime (Anthropic Messages API).
# Enable with the flag, then provide an API key to actually call the model.
# Without these, the orchestrator falls back to the deterministic `plan` runtime.
AGATHON_CLAUDE_CODE=
ANTHROPIC_API_KEY=
# Optional overrides:
ANTHROPIC_BASE_URL=https://api.anthropic.com
AGATHON_CLAUDE_MODEL=claude-opus-4-8
AGATHON_MAX_TOKENS=1024
AGATHON_TIMEOUT_MS=60000

# AGATHON Voice Reception telephony MVP.
# Configure Twilio phone number voice webhook to: https://<your-domain>/api/twilio/voice
TWILIO_WEBHOOK_BASE_URL=
TWILIO_PHONE_NUMBER=

{
  "name": "agathon-news-digest",
  "version": "0.1.0",
  "private": true,
  "description": "AGATHON LABS personal AI news digest MVP for Ion, reported by Ethan.",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "node scripts/build.mjs",
    "start": "node scripts/dev-server.mjs --dist",
    "test": "npm run build && node scripts/smoke-test.mjs && node scripts/orchestrator-test.mjs",
    "test:orchestrator": "node scripts/orchestrator-test.mjs",
    "orchestrate": "node scripts/orchestrate.mjs",
    "brief": "node scripts/daily-brief.mjs",
    "resume": "node scripts/resume.mjs",
    "fetch:rss": "node scripts/fetch-rss.mjs",
    "summarize": "node scripts/summarize-news.mjs",
    "check:docs-governance": "node scripts/check-docs-governance.mjs",
    "check:worktree-clean": "CHECK_WORKTREE_CLEAN=1 node scripts/check-docs-governance.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module"
}
